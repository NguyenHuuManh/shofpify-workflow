# =============================================================================
# Shopify Autonomous Store Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=shopify-autonomous-store
APP_URL=http://localhost:3000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://shopify:shopify@localhost:5432/shopify_autonomous

# -----------------------------------------------------------------------------
# Redis (for BullMQ queues and caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Shopify Admin API
# -----------------------------------------------------------------------------
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_access_token_here
SHOPIFY_API_VERSION=2024-04
SHOPIFY_API_SECRET=your_api_secret_here

# -----------------------------------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# -----------------------------------------------------------------------------
# Alternative AI Providers (optional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
AUTH_SECRET=generate_a_random_secret_here_min_32_chars
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# BullMQ Worker
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_AUTO_PUBLISH=false
ENABLE_IMAGE_GENERATION=false

# -----------------------------------------------------------------------------
# Supplemental Research Providers (optional)
# -----------------------------------------------------------------------------
# Search / competitor discovery
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Trend and keyword intelligence
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Ads signal intelligence
META_AD_LIBRARY_ACCESS_TOKEN=

# Supplier intelligence
SUPPLIER_PROVIDER_API_KEY=
SUPPLIER_PROVIDER_ENDPOINT=

# 1688 factory sourcing intelligence (legacy generic — retained for backward compat)
SOURCING_1688_PROVIDER=generic
SOURCING_1688_API_KEY=
SOURCING_1688_ENDPOINT=

# 1688 factory sourcing — DajiSaaS (primary vendor)
# DajiSaaS provides signed keyword-search and product-detail APIs for 1688.
SOURCING_1688_DAJISAAS_API_KEY=
SOURCING_1688_DAJISAAS_API_SECRET=
SOURCING_1688_DAJISAAS_ENDPOINT=https://openapi.dajisaas.com
SOURCING_1688_DAJISAAS_COUNTRY=en
# Required when Product Research target currency is USD. DajiSaaS prices are CNY.
SOURCING_1688_CNY_TO_USD_RATE=

# 1688 factory sourcing — Apify (sequential backup)
# Apify is called only when DajiSaaS is unavailable, fails, times out,
# is rate-limited, fails validation, or returns no usable evidence.
SOURCING_1688_APIFY_API_TOKEN=
SOURCING_1688_APIFY_ACTOR_ID=
SOURCING_1688_APIFY_ENDPOINT=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
