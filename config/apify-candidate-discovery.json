[
  {
    "actorId": "apify/e-commerce-scraping-tool",
    "label": "Apify E-commerce Scraping Tool",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "SearchEngineSearchKeyword": "{{query}}",
      "countryCode": "{{targetMarketLower}}",
      "scrapeProductsFromSearchEngine": true,
      "maxSearchEngineProducts": "{{maxItems}}",
      "maxSearchEngineResults": "{{maxItems}}",
      "additionalPropertiesSearchEngine": true
    }
  },
  {
    "actorId": "epctex/google-shopping-scraper",
    "label": "Apify Google Shopping Insights",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "queries": ["{{query}}"],
      "maxItems": "{{maxItems}}",
      "maxItemsPerQuery": "{{maxItems}}",
      "countryCode": "{{targetMarketLower}}",
      "includeComparisonPrices": true,
      "includeExtraProductDetails": false,
      "includeSponsoredResults": false,
      "proxy": {
        "useApifyProxy": true
      }
    }
  },
  {
    "actorId": "junglee/amazon-crawler",
    "label": "Apify Amazon Product Scraper",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "categoryOrProductUrls": [
        {
          "url": "https://www.amazon.com/s?k={{queryUrlEncoded}}"
        }
      ],
      "maxItemsPerStartUrl": "{{maxItems}}",
      "maxSearchPagesPerStartUrl": 1,
      "language": "en",
      "countryCode": "{{targetMarket}}",
      "scrapeProductDetails": false,
      "scrapeSellers": false,
      "useCaptchaSolver": false
    }
  },
  {
    "actorId": "pratikdani/tiktok-shop-scraper",
    "label": "Apify TikTok Shop Product Scraper",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "url": "{{query}}"
    }
  },
  {
    "actorId": "doliz/tiktok-creative-center-scraper",
    "label": "Apify TikTok Creative Center Ads",
    "sourceType": "ADS_SIGNAL",
    "providerType": "adsSignal",
    "maxItems": 10,
    "input": {
      "target": "top_ads_dashboard",
      "dashboard_search": "{{query}}",
      "dashboard_region": ["{{targetMarket}}"],
      "dashboard_period": "30",
      "dashboard_limit": "{{maxItems}}"
    }
  },
  {
    "actorId": "epctex/etsy-scraper",
    "label": "Apify Etsy Data Extractor",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "search": "{{query}}",
      "maxItems": "{{maxItems}}",
      "includeDescription": false,
      "includeVariationPrices": false,
      "proxy": {
        "useApifyProxy": true
      }
    }
  },
  {
    "actorId": "logical_scrapers/aliexpress-scraper",
    "label": "Apify AliExpress Scraper",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "startUrls": [
        {
          "url": "https://www.aliexpress.com/w/wholesale-{{queryUrlEncoded}}.html"
        }
      ],
      "maxItems": "{{maxItems}}",
      "proxyConfiguration": {
        "useApifyProxy": true
      }
    }
  },
  {
    "actorId": "dhrumil/shopify-products-scraper",
    "label": "Apify Shopify Products Scraper",
    "sourceType": "MARKETPLACE",
    "providerType": "marketplace",
    "maxItems": 10,
    "input": {
      "websiteUrl": "{{query}}",
      "proxy": {
        "useApifyProxy": true
      }
    }
  }
]
