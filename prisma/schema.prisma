// =============================================================================
// Prisma Schema - Shopify Autonomous Store Platform
// =============================================================================
// PostgreSQL database schema for all domain entities.
// Follows DDD document (03-ddd.md) exactly.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  ADMIN
  REVIEWER
  EDITOR
}

enum ProductStatus {
  DRAFT
  IN_PROGRESS
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum WorkflowStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
  CANCELLED
}

enum WorkflowStepType {
  RESEARCH
  RESEARCH_REVIEW
  CONTENT
  CONTENT_REVIEW
  SEO
  SEO_REVIEW
  LANDING
  LANDING_REVIEW
  IMAGE
  SHOPIFY
  REVIEW
  FINAL_REVIEW
  PUBLISH
}

enum StepStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum AgentRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum AssetType {
  HERO_IMAGE
  PRODUCT_IMAGE
  THUMBNAIL
  AD_CREATIVE
  LANDING_IMAGE
}

enum ResearchSourceType {
  SEARCH
  MARKETPLACE
  SOURCING
  TREND
  KEYWORD
  ADS_SIGNAL
  SUPPLIER
  SOCIAL
  AI_ESTIMATE
}

enum ResearchCandidateStatus {
  DISCOVERED
  SHORTLISTED
  APPROVED
  REJECTED
}

enum ResearchProjectStatus {
  ACTIVE
  SELECTED
  PROMOTED
  ARCHIVED
}

// =============================================================================
// Core Domain Models
// =============================================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  role         UserRole
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products  Product[]
  workflows Workflow[]
  approvals Approval[]
}

model Product {
  id          String        @id @default(cuid())
  title       String
  status      ProductStatus @default(DRAFT)
  workflowId  String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdBy       User?             @relation(fields: [createdById], references: [id])
  research        ProductResearch?
  researchRuns    ResearchRun[]
  candidates      ProductCandidate[]
  content         ProductContent?
  seo             ProductSEO?
  landingPage     LandingPage?
  assets          Asset[]
  shopifyResource ShopifyResource?

  @@index([status])
  @@index([createdAt])
}

model ProductResearch {
  id            String   @id @default(cuid())
  productId     String   @unique
  targetAudience Json
  competitors   Json
  painPoints    Json
  usp           Json
  marketSummary String
  selectedCandidateId String?
  generatedAt   DateTime

  product Product @relation(fields: [productId], references: [id])
}

model ResearchProject {
  id                  String                @id @default(cuid())
  query               String
  status              ResearchProjectStatus @default(ACTIVE)
  selectedCandidateId String?
  promotedProductId   String?
  summary             String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  researchRuns ResearchRun[]
  candidates   ProductCandidate[]

  @@index([status])
  @@index([createdAt])
}

model ResearchRun {
  id            String    @id @default(cuid())
  researchProjectId String?
  productId     String?
  workflowId    String?
  input         Json
  summary       String?
  recommendation Json?
  providerCosts Json?
  startedAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  researchProject ResearchProject?  @relation(fields: [researchProjectId], references: [id])
  product         Product?          @relation(fields: [productId], references: [id])
  candidates      ProductCandidate[]
  sources         ResearchSource[]

  @@index([researchProjectId])
  @@index([productId])
  @@index([workflowId])
  @@index([createdAt])
}

model ProductCandidate {
  id                     String                  @id @default(cuid())
  researchRunId          String
  researchProjectId      String?
  productId              String?
  name                   String
  positioning            String
  targetMarket           String?
  sellingAngle           String?
  recommendedPrice       Decimal?                @db.Decimal(10, 2)
  estimatedCOGS          Decimal?                @db.Decimal(10, 2)
  estimatedShipping      Decimal?                @db.Decimal(10, 2)
  factoryUnitCost        Decimal?                @db.Decimal(10, 2)
  moq                    Int?
  landedCost             Decimal?                @db.Decimal(10, 2)
  landedCostBreakdown    Json?
  estimatedGrossProfit   Decimal?                @db.Decimal(10, 2)
  grossMarginPercent     Decimal?                @db.Decimal(5, 2)
  breakEvenRoas          Decimal?                @db.Decimal(6, 2)
  demandScore            Int?
  trendScore             Int?
  competitionScore       Int?
  marginScore            Int?
  supplierScore          Int?
  sourcingScore          Int?
  factoryCostScore       Int?
  logisticsScore         Int?
  creativePotentialScore Int?
  riskScore              Int?
  winningScore           Int?
  confidence             String?
  status                 ResearchCandidateStatus @default(DISCOVERED)
  risks                  Json?
  metadata               Json?
  createdAt              DateTime                @default(now())

  researchRun     ResearchRun      @relation(fields: [researchRunId], references: [id])
  researchProject ResearchProject? @relation(fields: [researchProjectId], references: [id])
  product         Product?         @relation(fields: [productId], references: [id])
  sources         ResearchSource[]

  @@index([researchRunId])
  @@index([researchProjectId])
  @@index([productId])
  @@index([status])
  @@index([winningScore])
}

model ResearchSource {
  id              String             @id @default(cuid())
  researchRunId   String
  candidateId     String?
  type            ResearchSourceType
  provider        String
  url             String?
  externalId      String?
  title           String?
  extractedSignal String
  rawData         Json?
  confidence      Float?
  capturedAt      DateTime
  createdAt       DateTime           @default(now())

  researchRun ResearchRun       @relation(fields: [researchRunId], references: [id])
  candidate   ProductCandidate? @relation(fields: [candidateId], references: [id])

  @@index([researchRunId])
  @@index([candidateId])
  @@index([type])
}

model ProductContent {
  id          String   @id @default(cuid())
  productId   String   @unique
  headline    String
  subHeadline String?
  description String
  benefits    Json
  features    Json
  faq         Json
  generatedAt DateTime

  product Product @relation(fields: [productId], references: [id])
}

model ProductSEO {
  id              String   @id @default(cuid())
  productId       String   @unique
  metaTitle       String
  metaDescription String
  slug            String   @unique
  keywords        Json
  generatedAt     DateTime

  product Product @relation(fields: [productId], references: [id])
}

model LandingPage {
  id          String   @id @default(cuid())
  productId   String   @unique
  sections    Json
  generatedAt DateTime

  product Product @relation(fields: [productId], references: [id])
}

model Asset {
  id        String    @id @default(cuid())
  productId String
  type      AssetType
  url       String
  provider  String
  metadata  Json?
  createdAt DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model ShopifyResource {
  id                  String    @id @default(cuid())
  productId           String    @unique
  shopifyProductId    String?
  shopifyCollectionId String?
  shopifyPageId       String?
  published           Boolean   @default(false)
  syncedAt            DateTime?

  product Product @relation(fields: [productId], references: [id])

  @@index([published])
}

// =============================================================================
// Workflow & Orchestration
// =============================================================================

model Workflow {
  id          String           @id @default(cuid())
  productId   String
  userId      String?
  currentStep WorkflowStepType
  status      WorkflowStatus   @default(PENDING)
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user      User?          @relation(fields: [userId], references: [id])
  steps     WorkflowStep[]
  approvals Approval[]
  agentRuns AgentRun[]

  @@index([status])
  @@index([currentStep])
}

model WorkflowStep {
  id           String           @id @default(cuid())
  workflowId   String
  step         WorkflowStepType
  status       StepStatus       @default(PENDING)
  startedAt    DateTime
  completedAt  DateTime?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime         @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])

  @@index([workflowId])
}

model Approval {
  id         String         @id @default(cuid())
  workflowId String
  reviewerId String
  status     ApprovalStatus
  comment    String?
  createdAt  DateTime       @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])
  reviewer User     @relation(fields: [reviewerId], references: [id])

  @@index([workflowId])
}

// =============================================================================
// Observability & Audit
// =============================================================================

model AgentRun {
  id           String          @id @default(cuid())
  workflowId   String
  agentName    String
  status       AgentRunStatus  @default(RUNNING)
  startedAt    DateTime
  completedAt  DateTime?
  input        Json
  output       Json?
  errorMessage String?

  workflow Workflow @relation(fields: [workflowId], references: [id])

  @@index([workflowId])
}

model AIUsageLog {
  id               String   @id @default(cuid())
  provider         String
  model            String
  workflowId       String?
  agentRunId       String?
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  estimatedCost    Float
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([workflowId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

// =============================================================================
// Configuration
// =============================================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
